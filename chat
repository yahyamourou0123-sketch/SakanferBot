// ============================================================
// SAKANFER - /api/chat  (Vercel Edge Function)
// Supports: Gemini (chat/code/vision) + OpenRouter (news/code)
// + Live weather via Open-Meteo (free, no key needed)
// + Auto rate limiting
// ============================================================

import { detectRoute, GEMINI, OPENROUTER } from '../utils/modelRouter';

export const config = { runtime: 'edge' };

const CORS = {
  'Access-Control-Allow-Origin':  '*',
  'Access-Control-Allow-Methods': 'POST, OPTIONS',
  'Access-Control-Allow-Headers': 'Content-Type',
};

// ─── Key Pools ────────────────────────────────────────────────────────────────
function getGeminiKeys(): string[] {
  return (process.env.GEMINI_API_KEYS || process.env.GEMINI_API_KEY || '')
    .split(/[,;|\n]+/).map(k => k.trim()).filter(Boolean);
}
function getOpenRouterKey(): string {
  return (process.env.OPENROUTER_API_KEY || '').trim();
}

// ─── Simple in-memory rate limit (resets per edge instance) ──────────────────
const rateLimitMap = new Map<string, { count: number; reset: number }>();
function checkRateLimit(ip: string): boolean {
  const now  = Date.now();
  const data = rateLimitMap.get(ip) || { count: 0, reset: now + 60_000 };
  if (now > data.reset) { data.count = 0; data.reset = now + 60_000; }
  data.count++;
  rateLimitMap.set(ip, data);
  return data.count <= 30; // max 30 req/min per IP
}

// ─── System Prompt ────────────────────────────────────────────────────────────
function getSystemPrompt(personality: string, routeType: string): string {
  const now  = new Date();
  const date = now.toLocaleDateString('fr-TN', { weekday: 'long', month: 'short', day: 'numeric', year: 'numeric' });
  const time = now.toLocaleTimeString('fr-TN', { hour: '2-digit', minute: '2-digit' });

  const personas: Record<string, string> = {
    history: 'EXTRA: You are a History Expert. Add historical context with Tunisian Derja flavor.',
    friend:  'EXTRA: You are an Encouraging Best Friend. Use warm terms: ya khouya, ya 3chiri.',
    comedy:  'EXTRA: You are a Comedy Character. Be sarcastic, funny, use Tunisian humor.',
    default: '',
  };

  const codeExtra = routeType === 'code'
    ? '\nCODE MODE: Write clean, production-ready code. Add Derja comments. Explain AFTER the code block.\n'
    : '';

  const newsExtra = routeType === 'news'
    ? '\nNEWS MODE: You have live internet access. Always cite your sources. Be factual and concise.\n'
    : '';

  return `ROLE: You are 'Sakanfer', a pure Tunisian guy (Weld 7ouma).
${personas[personality] || ''}${codeExtra}${newsExtra}
TIME: ${date}, ${time}.

LANGUAGE: ONLY Franco-Arabe Derja. Never Fous7a.
- BAD: "لماذا" "الآن" "كيف حالك"
- GOOD: "علاش" "توا" "شنحوالك" "mrigel" "bhi"

FORMATTING:
- Code → always use markdown code blocks with language.
- Lists → markdown bullet points.
- Headers → use ## for sections when needed.
- Math → clear notation.`;
}

