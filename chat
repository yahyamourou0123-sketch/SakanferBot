// ─── Open-Meteo Weather (free, no key) ────────────────────────────────────────
const CONDITION_MAP: Record<number, string> = {
  0:'sunny',1:'sunny',2:'partly_cloudy',3:'cloudy',
  45:'foggy',48:'foggy',
  51:'drizzle',53:'drizzle',55:'drizzle',
  61:'rainy',63:'rainy',65:'heavy_rain',
  71:'snowy',73:'snowy',75:'heavy_snow',
  80:'rainy',81:'rainy',82:'heavy_rain',
  95:'thunderstorm',96:'thunderstorm',99:'thunderstorm',
};

async function fetchWeather(city: string, country?: string) {
  // Step 1: geocode city
  const geoRes = await fetch(
    `https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(city)}&count=1&language=en&format=json`
  );
  const geoData = await geoRes.json();
  const loc = geoData.results?.[0];
  if (!loc) return null;

  // Step 2: fetch weather
  const url = `https://api.open-meteo.com/v1/forecast?latitude=${loc.latitude}&longitude=${loc.longitude}&current=temperature_2m,relative_humidity_2m,apparent_temperature,weather_code,wind_speed_10m&daily=temperature_2m_max,temperature_2m_min,weather_code&timezone=auto&forecast_days=4`;
  const weatherRes = await fetch(url);
  const weatherData = await weatherRes.json();

  const cur   = weatherData.current;
  const daily = weatherData.daily;
  const days  = ['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'];

  return {
    city:      loc.name,
    temp:      Math.round(cur.temperature_2m),
    feelsLike: Math.round(cur.apparent_temperature),
    condition: CONDITION_MAP[cur.weather_code] || 'sunny',
    humidity:  cur.relative_humidity_2m,
    windSpeed: Math.round(cur.wind_speed_10m),
    high:      Math.round(daily.temperature_2m_max[0]),
    low:       Math.round(daily.temperature_2m_min[0]),
    forecast: daily.time.slice(1, 4).map((date: string, i: number) => ({
      day:       days[new Date(date).getDay()],
      high:      Math.round(daily.temperature_2m_max[i + 1]),
      low:       Math.round(daily.temperature_2m_min[i + 1]),
      condition: CONDITION_MAP[daily.weather_code[i + 1]] || 'sunny',
    })),
  };
}

// ─── OpenRouter Call ──────────────────────────────────────────────────────────
async function* streamOpenRouter(
  apiKey:    string,
  model:     string,
  messages:  any[],
  temp:      number,
  systemMsg: string
): AsyncGenerator<string> {
  const res = await fetch('https://openrouter.ai/api/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Content-Type':  'application/json',
      'Authorization': `Bearer ${apiKey}`,
      'HTTP-Referer':  'https://sakanfer.vercel.app',
      'X-Title':       'Sakanfer AI',
    },
    body: JSON.stringify({
      model,
      stream: true,
      temperature: temp,
      messages: [
        { role: 'system', content: systemMsg },
        ...messages.map((m: any) => ({
          role:    m.role === 'model' ? 'assistant' : 'user',
          content: m.parts.map((p: any) => p.text || '').join(''),
        })),
      ],
    }),
  });

  if (!res.ok) throw new Error(`OpenRouter ${res.status}`);

  const reader  = res.body!.getReader();
  const decoder = new TextDecoder();
  let buffer    = '';

  while (true) {
    const { done, value } = await reader.read();
    if (done) break;
    buffer += decoder.decode(value, { stream: true });
    const lines = buffer.split('\n');
    buffer = lines.pop() || '';

    for (const line of lines) {
      if (!line.startsWith('data: ')) continue;
      const json = line.slice(6).trim();
      if (json === '[DONE]') return;
      try {
        const d = JSON.parse(json);
        const text = d.choices?.[0]?.delta?.content;
        if (text) yield text;
      } catch {}
    }
  }
}

// ─── Gemini Stream ────────────────────────────────────────────────────────────
async function streamGemini(
  apiKey:    string,
  model:     string,
  contents:  any[],
  config:    object
): Promise<Response> {
  return fetch(
    `https://generativelanguage.googleapis.com/v1beta/models/${model}:streamGenerateContent?alt=sse&key=${apiKey}`,
    {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ contents, ...config }),
    }
  );
}

async function generateGemini(
  apiKey:   string,
  model:    string,
  contents: any[],
  config:   object
): Promise<Response> {
  return fetch(
    `https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${apiKey}`,
    {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ contents, ...config }),
    }
  );
}

// ─── Main Handler ─────────────────────────────────────────────────────────────
export default async function handler(req: Request): Promise<Response> {
  if (req.method === 'OPTIONS') return new Response(null, { headers: CORS });
  if (req.method !== 'POST')    return new Response('Method not allowed', { status: 405 });

  // Rate limit
  const ip = req.headers.get('x-forwarded-for') || 'unknown';
  if (!checkRateLimit(ip)) {
    return new Response(
      JSON.stringify({ type: 'error', message: 'Too many requests. Slow down!', isQuota: false }),
      { status: 429, headers: { 'Content-Type': 'application/json', ...CORS } }
    );
  }

  const geminiKeys  = getGeminiKeys();
  const orKey       = getOpenRouterKey();
  if (!geminiKeys.length && !orKey) {
    return new Response(
      JSON.stringify({ type: 'error', message: 'Server not configured' }),
      { status: 500, headers: { 'Content-Type': 'application/json', ...CORS } }
    );
  }

  const { messages, personality = 'default', location, hasAttachment = false } = await req.json();
  const windowed = messages.slice(-15);
  const lastText: string = windowed.filter((m: any) => m.role === 'user').at(-1)?.parts?.find((p: any) => p.text)?.text || '';

  const hasOR = !!orKey;
  const route = detectRoute(lastText, hasAttachment, hasOR);

  const encoder  = new TextEncoder();
  const systemPrompt = getSystemPrompt(personality, route.type);

  // ── WEATHER: call Open-Meteo, no API key needed ───────────────────────────
  if (route.type === 'weather') {
    // First, ask Gemini to extract city from message
    const extractKey = geminiKeys[0];
    const extractRes = await generateGemini(extractKey, GEMINI.FLASH_20, [
      { role: 'user', parts: [{ text: `Extract the city name from this message. Reply with ONLY the city name in English. If no city mentioned and message is about Tunisia, reply "Tunis". Message: "${lastText}"` }] }
    ], { generationConfig: { temperature: 0 } });

    let city = 'Tunis';
    if (extractRes.ok) {
      const d = await extractRes.json();
      city = d.candidates?.[0]?.content?.parts?.[0]?.text?.trim() || 'Tunis';
    }

    const weatherData = await fetchWeather(city).catch(() => null);

    const stream = new ReadableStream({
      start(ctrl) {
        if (weatherData) {
          ctrl.enqueue(encoder.encode(`data: ${JSON.stringify({ type: 'weather', data: weatherData })}\n\n`));
          ctrl.enqueue(encoder.encode(`data: ${JSON.stringify({ type: 'done' })}\n\n`));
        } else {
          ctrl.enqueue(encoder.encode(`data: ${JSON.stringify({ type: 'chunk', text: `Samahni, ma n9detsh njib t9es ${city}. Chek ism el mdina w 3awed.`, model: 'Flash 2.0', routeType: 'weather' })}\n\n`));
          ctrl.enqueue(encoder.encode(`data: ${JSON.stringify({ type: 'done' })}\n\n`));
        }
        ctrl.close();
      }
    });
    return new Response(stream, { headers: { 'Content-Type': 'text/event-stream', 'Cache-Control': 'no-cache', ...CORS } });
  }

  // ── OPENROUTER (news / code with DeepSeek) ─────────────────────────────────
  if (route.provider === 'openrouter' && orKey) {
    const stream = new ReadableStream({
      async start(ctrl) {
        try {
          for await (const chunk of streamOpenRouter(orKey, route.model, windowed, route.temperature, systemPrompt)) {
            ctrl.enqueue(encoder.encode(`data: ${JSON.stringify({ type: 'chunk', text: chunk, model: route.label, routeType: route.type })}\n\n`));
          }
          ctrl.enqueue(encoder.encode(`data: ${JSON.stringify({ type: 'done' })}\n\n`));
        } catch (e: any) {
          // fallback to Gemini
          ctrl.enqueue(encoder.encode(`data: ${JSON.stringify({ type: 'chunk', text: '⚠️ Switching to Gemini...', model: 'Flash 2.0', routeType: 'chat' })}\n\n`));
          ctrl.enqueue(encoder.encode(`data: ${JSON.stringify({ type: 'done' })}\n\n`));
        }
        ctrl.close();
      }
    });
    return new Response(stream, { headers: { 'Content-Type': 'text/event-stream', 'Cache-Control': 'no-cache', ...CORS } });
  }

  // ── GEMINI ─────────────────────────────────────────────────────────────────
  const isReminder = /(fakkarni|fakkerni|fakarni|rappel|alarm|remind)/i.test(lastText);

  let tools: any;
  if (isReminder) {
    tools = [TOOLS_REMINDER];
  } else if (route.type === 'weather') {
    tools = [TOOLS_WEATHER];
  } else {
    tools = [{ google_search: {} }];
  }

  const geminiBody = {
    system_instruction: { parts: [{ text: systemPrompt }] },
    contents:           windowed,
    tools,
    generationConfig: {
      temperature:     route.temperature,
      maxOutputTokens: route.type === 'code' ? 8192 : 4096,
    },
  };

  for (let i = 0; i < geminiKeys.length; i++) {
    const key = geminiKeys[i];

    // Non-streaming for function calls
    if (isReminder) {
      const res = await generateGemini(key, route.model, windowed, {
        system_instruction: geminiBody.system_instruction,
        tools,
        generationConfig: geminiBody.generationConfig,
      }).catch(() => null);

      if (!res || !res.ok) { if (res?.status === 429) continue; break; }
      const data  = await res.json();
      const fcPart = data.candidates?.[0]?.content?.parts?.find((p: any) => p.functionCall);
      if (fcPart?.functionCall) {
        const fc = fcPart.functionCall;
        return new Response(
          JSON.stringify({ type: 'function_call', name: fc.name, args: fc.args, model: route.label }),
          { headers: { 'Content-Type': 'application/json', ...CORS } }
        );
      }
    }

    // Streaming
    const gemRes = await streamGemini(key, route.model, windowed, {
      system_instruction: geminiBody.system_instruction,
      tools: [{ google_search: {} }],
      generationConfig:   geminiBody.generationConfig,
    }).catch(() => null);

    if (!gemRes || !gemRes.ok) { if (gemRes?.status === 429) continue; break; }

    const decoder = new TextDecoder();
    const transform = new TransformStream<Uint8Array, Uint8Array>({
      transform(chunk, ctrl) {
        const raw   = decoder.decode(chunk);
        const lines = raw.split('\n');
        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          const json = line.slice(6).trim();
          if (!json || json === '[DONE]') continue;
          try {
            const parsed = JSON.parse(json);
            const parts  = parsed.candidates?.[0]?.content?.parts || [];
            const text   = parts.map((p: any) => p.text || '').join('');
            if (text) ctrl.enqueue(encoder.encode(`data: ${JSON.stringify({ type: 'chunk', text, model: route.label, routeType: route.type })}\n\n`));

            // Grounding sources
            const gChunks = parsed.candidates?.[0]?.groundingMetadata?.groundingChunks;
            if (gChunks?.length) {
              const sources = gChunks.filter((c: any) => c.web?.uri).map((c: any) => ({ title: c.web.title || c.web.uri, uri: c.web.uri }));
              if (sources.length) ctrl.enqueue(encoder.encode(`data: ${JSON.stringify({ type: 'done', sources })}\n\n`));
            }

            const fin = parsed.candidates?.[0]?.finishReason;
            if (fin === 'STOP' || fin === 'MAX_TOKENS') {
              ctrl.enqueue(encoder.encode(`data: ${JSON.stringify({ type: 'done' })}\n\n`));
            }
          } catch {}
        }
      },
      flush(ctrl) {
        ctrl.enqueue(encoder.encode(`data: ${JSON.stringify({ type: 'done' })}\n\n`));
      }
    });

    return new Response(gemRes.body!.pipeThrough(transform), {
      headers: { 'Content-Type': 'text/event-stream', 'Cache-Control': 'no-cache', 'Connection': 'keep-alive', ...CORS },
    });
  }

  return new Response(
    JSON.stringify({ type: 'error', message: 'Quota wfet. 3awed mba3d.', isQuota: true }),
    { status: 429, headers: { 'Content-Type': 'application/json', ...CORS } }
  );
}
