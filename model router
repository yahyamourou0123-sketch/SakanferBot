export type RouteType = 'chat' | 'code' | 'analysis' | 'math' | 'vision' | 'creative' | 'news' | 'weather';
export type Provider  = 'gemini' | 'openrouter';

export interface RouteDecision {
  model:       string;
  provider:    Provider;
  label:       string;
  type:        RouteType;
  temperature: number;
  emoji:       string;
  color:       string;
}

