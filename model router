// ─── patterns للكشف ──────────────────────────────────────────────────────────
const CODE_PAT = [
  /\b(code|function|debug|bug|error|class|import|export|javascript|python|typescript|react|html|css|sql|algorithm|program|script|component|api|regex|json|array|loop|variable|syntax|compile|build|npm|git|bash|dockerfile|refactor|implement|كود|برمجة|خطأ)\b/i,
  /```[\s\S]*/,
  /def |const |let |var |return |print\(|console\./,
  /\.(js|ts|py|java|cpp|go|rs|php)$/,
];
const NEWS_PAT = [
  /\b(khabar|akhbar|nouvelles|news|aktu|breaking|lyoum|lioum|aujourd|this week|sar chi|chay jadid|trending)\b/i,
  /\b(tunisie|tunisia|monde|world|politique|sport|foot|match)\b.*\b(lyoum|today|now|maintenant|tawa)\b/i,
];
const ANALYSIS_PAT = [
  /\b(analyse|analyze|summarize|compare|explain in detail|document|pdf|research|report|review|evaluate|breakdown)\b/i,
  /\b(economics|legal|medical|finance|strategy|business|investment)\b/i,
];
const MATH_PAT = [
  /\b(calculate|solve|equation|formula|derivative|integral|matrix|probability|statistics|calculus|algebra|7seb|9sm|jm3)\b/i,
  /[∫∑∏√≈≠≤≥±∞]/,
  /\d+\s*[\+\-\*\/\^]\s*\d+/,
];
const CREATIVE_PAT = [
  /\b(write|story|poem|song|creative|fiction|narrative|script|dialogue|roman|9essa|shi3r)\b/i,
];
const WEATHER_PAT = [
  /\b(t9es|ta9s|meteo|météo|weather|température|berd|s5ana|chta|7al|climate)\b/i,
  /\b(pluie|soleil|nuage|vent|rain|sun|cloud|wind|snow|neige|7ar|bared)\b/i,
];

// ─── الدالة الرئيسية ──────────────────────────────────────────────────────────
export function detectRoute(
  message:       string,
  hasAttachment: boolean = false,
  hasOpenRouter: boolean = false
): RouteDecision {
  if (hasAttachment)                             return ROUTES.vision;
  if (WEATHER_PAT.some(p => p.test(message)))   return ROUTES.weather;
  if (NEWS_PAT.some(p => p.test(message)))      return hasOpenRouter ? ROUTES.news      : ROUTES.chat;
  if (CODE_PAT.some(p => p.test(message)))      return hasOpenRouter ? ROUTES.code      : ROUTES.code_gemini;
  if (MATH_PAT.some(p => p.test(message)))      return ROUTES.math;
  if (ANALYSIS_PAT.some(p => p.test(message)))  return ROUTES.analysis;
  if (CREATIVE_PAT.some(p => p.test(message)))  return ROUTES.creative;
  // ✅ كل شيء ثاني = Gemini Flash الأصلي (Sakanfer)
  return ROUTES.chat;
}

